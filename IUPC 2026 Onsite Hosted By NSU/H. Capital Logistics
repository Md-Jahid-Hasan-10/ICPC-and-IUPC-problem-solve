const ll oo = 1e18;
const ll mod = 1e9 + 7;
const ll N = 2e5 + 123;

int n,k,val[N];
vi graph[N];

pii dfs(int node,int par,int day){
    int mx = 0,sum = 0;
    for(auto u : graph[node]){
        if(u == par)continue;
        auto ch = dfs(u,node,day);
        mx = max(mx,ch.F);
        sum += ch.S;
    }
    mx += val[node];
    if(mx > day){
        sum += (mx - day);
        mx = day;
    }
    return {mx,sum};
}
void Goriber_solve()
{
    cin >> n >> k;
    for(int i = 1; i <= n; i++){
        graph[i].clear();
    }
    for(int i = 2; i <= n; i++){
        int p;
        cin >> p;
        graph[i].pb(p);
        graph[p].pb(i);
    }
    for(int i = 1; i <= n; i++){
        cin >> val[i];
    }
    int lo = 0,hi = 1e16,ans = oo;
    while(lo <= hi){
        int mid = (lo + hi)/2;
        auto x = dfs(1,-1,mid);
        //cout << mid << " " << x.F << " " << x.S << endl;
        if(x.S > k){
            lo = mid + 1;
        }
        else{
            hi = mid - 1;
            ans = min(ans,mid);
        }
    }
    cout << ans << endl;
}

