const ll oo = 1e18;
const ll mod = 1e9 + 7;
const ll N = sqrt(mod) + 1;
vector<int> primes;
bitset<N>is_prime;

void sieve_v0() {
  for (int i = 3; i < N; i += 2) {
    is_prime[i] = 1;
  }
  for (int i = 3; i * i < N; i += 2) {
    if (is_prime[i]) {
      for (int j = i * i; j < N; j += i) {
        is_prime[j] = 0;
      }
    }
  }
  is_prime[2] = 1;
  for (int i = 2; i < N; i++) {
    if(is_prime[i]){
      primes.push_back(i);
    }
  }
}
void Goriber_solve()
{
    int n;
    cin >> n;
    int ans = 1,ok = 0;
    for(auto &u : primes){
        if(u * u > n)break;
        int e = 0;
        while(n % u == 0){
            n /= u;
            e++;
        }
        if(e & 1)ok = 1;
        ans *= ((e/2) + 1);
    }
    if(n > 1)ok = 1;
    if(!ok)ans--;
    cout << ans << endl;
}

