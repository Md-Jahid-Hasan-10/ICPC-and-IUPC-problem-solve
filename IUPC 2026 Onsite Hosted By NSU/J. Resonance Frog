const int INF = INT_MAX / 2;

void Goriber_solve()
{
    int n;
    cin >> n;
    vi a(n + 1), b(n + 1);
    for(int i = 1; i <= n; i++) cin >> a[i];
    for(int i = 1; i <= n; i++) cin >> b[i];
    vi all_vals;
    all_vals.reserve(2 * n);
    for(int i = 1; i <= n; i++){
        all_vals.push_back(a[i]);
        all_vals.push_back(b[i]);
    }
    sort(all(all_vals));
    all_vals.erase(unique(all(all_vals)), all_vals.end());
    
    auto get_idx = [&](int x) {
        return lower_bound(all(all_vals), x) - all_vals.begin();
    };
    for(int i = 1; i <= n; i++){
        a[i] = get_idx(a[i]);
        b[i] = get_idx(b[i]);
    }
    int m = sz(all_vals);
    vector<priority_queue<pii, vii, greater<pii>>> pq(m);
    vi last_occ(m, 0);
    vector<int> dp(n + 2, INF);
    dp[1] = 0;
    
    for(int k = 1; k <= n; k++){
        if(k > 1 && dp[k - 1] + 1 < dp[k]){
            dp[k] = dp[k - 1] + 1;
        }
        int fb = b[k];
        auto &heap = pq[fb];
        while(!heap.empty() && heap.top().second <= k){
            heap.pop();
        }
        if(!heap.empty()){
            int cand = heap.top().first + 1;
            if(cand < dp[k])dp[k] = cand;
        }
        if (dp[k] < INF) {
            int fa = a[k];
            int j = last_occ[fa];
            
            if(j != 0 && j < k){
                long long m_dest = 2LL * k - j;
                if(m_dest <= n){
                    if(dp[k] + 1 < dp[(int)m_dest]){
                        dp[(int)m_dest] = dp[k] + 1;
                    }
                }
                pq[fa].push({dp[k],m_dest});
            }
        }
        last_occ[fb] = k;
    }
    
    cout << dp[n] << endl;
}

