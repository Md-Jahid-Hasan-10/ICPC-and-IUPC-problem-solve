#include <bits/stdc++.h>
using namespace std;
#define int long long

signed main(){
    int t = 1;
    ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        set<int> st;
        for(int i = 1; i <= n; i++)st.insert(i);
        int ar[n+2];
        for(int i = 1; i <= n; i++){
            cin >> ar[i];
            if(ar[i] != -1)st.erase(ar[i]);
        }
        for(int i = 1; i <= n; i++){
            if(ar[i] != -1){
                cout << ar[i] << " ";
            }
            else{
                ar[i] = *--st.end();
                cout << ar[i] << " ";
                st.erase(ar[i]);
            }
            
        }
        cout << endl;
    }
    return 0;
}
