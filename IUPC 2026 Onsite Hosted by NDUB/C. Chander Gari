#include <bits/stdc++.h>
using namespace std;
#define int long long

signed main(){
    int t = 1;
    ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);
    cin >> t;
    while (t--) {
        int n,c,r;
        cin >> n >> c >> r;
        int ar[n+2];
        for(int i = 1; i <= n; i++){
            cin >> ar[i];
        }
        int lage[n+2] = {0};
        for(int i = n - 1; i >= 0; i--){
            lage[i] = lage[i+1] + ar[i+1];
            lage[i] = max(0LL,lage[i] - r);
        }
        if(lage[0] > c - r){
            cout << "Impossible" << endl;
            continue;
        }
        int cur = c - ar[1];
        vector<char> ans(n+2,'0');
        bool ok = 1;
        for(int i = 1; i < n; i++){
            if(lage[i+1] + ar[i+1] > cur){
                cur += r;
                if(cur > c)cur = c;
                if(lage[i+1] + ar[i+1] > cur){
                    ok = 0;
                    break;
                }
                ans[i] = '1';
            }
            cur -= ar[i+1];
        }
        if(ok == 0){
            cout << "Impossible" << endl;
            continue;
        }
        for(int i = 1; i <= n; i++){
            cout << ans[i];
        }
        cout << endl;
    }
    return 0;
}
