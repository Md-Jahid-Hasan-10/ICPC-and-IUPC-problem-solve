#include <bits/stdc++.h>
using namespace std;

struct BIT {
    int n;
    vector<long long> mn;
    BIT(int n): n(n), mn(n+2, LLONG_MAX) {}
    void update(int i, long long v){
        for(i++; i<=n; i+=i&-i) mn[i]=min(mn[i],v);
    }
    long long query(int i){
        long long res=LLONG_MAX;
        for(i++; i>0; i-=i&-i) res=min(res,mn[i]);
        return res;
    }
};

int main(){
    int t;
    cin >> t;
    while(t--){
        int n,k; long long x;
        cin >> n >> k >> x;
        vector<long long> a(n);
        for(auto &v:a) scanf("%lld",&v);
        vector<long long> P1(n+1,0), P2(n+1,0);
        for(int i=0;i<n;i++){
            P1[i+1]=P1[i]+(a[i]>=x?1:-1);
            P2[i+1]=P2[i]+(a[i]<=x?1:-1);
        }
        vector<int> last_x(n,-1);
        for(int r=0;r<n;r++){
            if(r>0) last_x[r]=last_x[r-1];
            if(a[r]==x) last_x[r]=r;
        }
        vector<long long> vals(P1.begin(),P1.end());
        sort(vals.begin(),vals.end());
        vals.erase(unique(vals.begin(),vals.end()),vals.end());
        int sz=(int)vals.size();
        auto getIdx=[&](long long v){
            return (int)(lower_bound(vals.begin(),vals.end(),v)-vals.begin());
        };

        BIT bit(sz);
        bool found=false;
        int addPtr=0;
        for(int r=0;r<n&&!found;r++){
            if(last_x[r]<0) continue;
            int ub=min(r-k+1, last_x[r]);
            while(addPtr<=ub){
                int ci=getIdx(P1[addPtr]);
                bit.update(ci, P2[addPtr]);
                addPtr++;
            }
            if(ub<0) continue;
            int ci=(int)(lower_bound(vals.begin(),vals.end(),P1[r+1])-vals.begin())-1;
            if(ci>=0){
                long long minP2=bit.query(ci);
                if(minP2!=LLONG_MAX && minP2<=P2[r+1])
                    found=true;
            }
        }
        printf("%s\n",found?"Yes":"No");
    }
    return 0;
}
